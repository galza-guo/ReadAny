{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "readani",
  "version": "1.1.0",
  "identifier": "com.xnu.readani",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "readani",
        "width": 1400,
        "height": 850,
        "backgroundColor": "#1c1c1e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Desktop bilingual PDF and EPUB reader for side-by-side translation.",
    "macOS": {
      "infoPlist": "./Info.plist",
      "entitlements": "./Entitlements.plist",
      "minimumSystemVersion": "15.0"
    },
    "category": "Utility",
    "iOS": {
      "infoPlist": "Info.iOS.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdEQzM5M0U3M0U4MDE1NzQKUldSMEZZQSs1NVBEZlFYc2k3K3B4eVhsaXZWNGdZek92dHQxa1gzc21EVUcwUVBiU1hiTDN5WE4K",
      "endpoints": [
        "https://github.com/galza-guo/readani/releases/latest/download/latest.json"
      ]
    }
  }
}
